#!/bin/sh

DATE=`date +%Y-%m-%d`

curl -X POST https://content.dropboxapi.com/2/files/upload \
    --header "Authorization: Bearer {{ dropbox_token }}" \
    --header "Dropbox-API-Arg: {\"path\": \"/{{ node_webpage_service_name  }}_$DATE.db\"}" \
    --header "Content-Type: application/octet-stream" \
    --data-binary @{{ node_webpage_root }}/data/{{ node_webpage_db_file_name }}
